---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home" description="Technical Architect and AI Explorer documenting the journey from enterprise systems to artificial intelligence.">

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="max-w-2xl">
      <p class="text-brand-600 font-semibold text-sm tracking-widest uppercase mb-4">Technical Architect & AI Explorer</p>
      <h1 class="text-5xl sm:text-6xl font-bold text-ink-900 leading-tight mb-6">
        Hi, I'm <span class="text-brand-600">Mike Betz.</span>
      </h1>
      <p class="text-xl text-ink-700 leading-relaxed mb-4">
        I've spent years architecting enterprise systems — databases, integrations, commerce platforms.
        Now I'm going deep on AI and documenting every step of the journey.
      </p>
      <p class="text-lg text-ink-500 leading-relaxed mb-10">
        Husband. Father of three. Based in Medina, Ohio.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/blog" class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
          Read the Blog
        </a>
        <a href="/contact" class="border border-ink-300 hover:border-brand-400 text-ink-700 hover:text-brand-600 font-semibold px-6 py-3 rounded-xl transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <hr class="border-ink-100" />
  </div>

  <!-- About strip -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="grid sm:grid-cols-3 gap-8 text-center">
      <div class="p-6">
        <div class="text-3xl font-bold text-brand-600 mb-2">20+</div>
        <div class="text-ink-700 font-medium">Years in Enterprise Tech</div>
        <p class="text-ink-400 text-sm mt-1">SQL, Java, SAP Hybris, PeopleSoft & more</p>
      </div>
      <div class="p-6">
        <div class="text-3xl font-bold text-brand-600 mb-2">Now</div>
        <div class="text-ink-700 font-medium">Going Deep on AI</div>
        <p class="text-ink-400 text-sm mt-1">Learning, building, and sharing in public</p>
      </div>
      <div class="p-6">
        <div class="text-3xl font-bold text-brand-600 mb-2">Here</div>
        <div class="text-ink-700 font-medium">The Unfiltered Journey</div>
        <p class="text-ink-400 text-sm mt-1">Real experiments. Real results. No fluff.</p>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-ink-900">Latest Posts</h2>
        <a href="/blog" class="text-brand-600 hover:text-brand-700 text-sm font-medium transition-colors">
          All posts &rarr;
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    </section>
  )}

</BaseLayout>
