---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();

// Find related posts: same tags first, then fall back to most recent
const related = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => ({
    ...p,
    sharedTags: p.data.tags.filter(t => post.data.tags.includes(t)).length,
  }))
  .sort((a, b) => b.sharedTags - a.sharedTags || b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2)
  .map(({ data, slug }) => ({ title: data.title, description: data.description, slug, tags: data.tags, date: data.date }));
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  relatedPosts={related}
>
  <Content />
</BlogLayout>
