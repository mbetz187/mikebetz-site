---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="AI & Enterprise Tech Blog | Mike Betz" description="Thoughts, experiments, and lessons learned at the intersection of enterprise tech and AI. From SQL and SAP to LLMs — real projects, honest takes.">
  <section class="relative max-w-5xl mx-auto px-6 py-16 overflow-hidden">
    <!-- Subtle grid background -->
    <div class="tech-grid absolute inset-0 text-ink-900 dark:text-white opacity-[0.03] dark:opacity-[0.05] pointer-events-none" aria-hidden="true"></div>

    <div class="relative mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-highlight-500"></div>
        <p class="font-mono text-xs text-highlight-500 tracking-widest uppercase">Writing</p>
      </div>
      <h1 class="text-4xl font-bold text-ink-900 dark:text-gray-100 mb-3">Blog</h1>
      <p class="text-ink-500 dark:text-ink-400 text-lg max-w-xl">
        Documenting the journey from enterprise architect to AI practitioner. Real experiments, honest takes.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-ink-400 dark:text-ink-500 font-mono text-sm">// No posts yet. Check back soon.</p>
    ) : (
      <div class="relative grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
