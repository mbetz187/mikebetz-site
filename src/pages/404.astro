---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Head back to Mike Betz's blog on AI and enterprise tech.">
  <section class="relative max-w-2xl mx-auto px-6 py-32 text-center overflow-hidden">
    <div class="tech-grid absolute inset-0 text-ink-900 dark:text-white opacity-[0.04] dark:opacity-[0.06] pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-brand-600/10 dark:bg-brand-600/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative">
      <p class="font-mono text-xs text-highlight-500 tracking-widest uppercase mb-6">404 — Not Found</p>
      <h1 class="text-6xl font-bold mb-4">
        <span class="gradient-text">Lost?</span>
      </h1>
      <p class="text-xl text-ink-500 dark:text-ink-400 mb-10">
        This page doesn't exist. It may have been moved, deleted, or you followed a bad link.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 glow-brand"
        >
          Go Home
        </a>
        <a
          href="/blog"
          class="border border-ink-300 dark:border-ink-700 hover:border-brand-500 dark:hover:border-brand-600 text-ink-700 dark:text-ink-200 hover:text-brand-600 dark:hover:text-brand-400 font-semibold px-6 py-3 rounded-xl transition-colors"
        >
          Read the Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
