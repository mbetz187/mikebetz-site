---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Mike Betz.">
  <section class="relative max-w-2xl mx-auto px-6 py-16 overflow-hidden">
    <!-- Glow orbs -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-accent-600/10 dark:bg-accent-600/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-brand-600/10 dark:bg-brand-600/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-highlight-500"></div>
        <p class="font-mono text-xs text-highlight-500 tracking-widest uppercase">Reach Out</p>
      </div>
      <h1 class="text-4xl font-bold text-ink-900 dark:text-gray-100 mb-3">Get in Touch</h1>
      <p class="text-ink-500 dark:text-ink-400 text-lg">
        Have a question, want to collaborate, or just want to talk tech? Pick a channel below.
      </p>
    </div>

    <div class="relative flex flex-col gap-4">

      <!-- Email -->
      <a
        href="mailto:michaelb187@gmail.com"
        class="group flex items-center gap-5 p-6 rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-800/40 hover:border-brand-400 dark:hover:border-brand-700 hover:shadow-lg dark:hover:shadow-brand-600/10 transition-all duration-300 overflow-hidden relative"
      >
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-600/0 to-brand-600/0 group-hover:from-brand-600/[0.04] group-hover:to-highlight-500/[0.04] dark:group-hover:from-brand-600/10 dark:group-hover:to-highlight-500/10 transition-all duration-300 pointer-events-none"></div>
        <div class="shrink-0 w-12 h-12 rounded-xl bg-brand-50 dark:bg-brand-900/30 border border-brand-100 dark:border-brand-800 flex items-center justify-center text-brand-600 dark:text-brand-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-mono font-medium text-ink-400 dark:text-ink-500 mb-0.5 uppercase tracking-wide">Email</p>
          <p class="text-ink-900 dark:text-gray-100 font-semibold">michaelb187@gmail.com</p>
          <p class="text-ink-400 dark:text-ink-500 text-sm mt-0.5">Opens in your default mail app</p>
        </div>
        <svg class="w-5 h-5 text-ink-300 dark:text-ink-600 group-hover:text-brand-500 dark:group-hover:text-brand-400 group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/betzmichael/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 p-6 rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-800/40 hover:border-accent-400 dark:hover:border-accent-700 hover:shadow-lg dark:hover:shadow-accent-600/10 transition-all duration-300 overflow-hidden relative"
      >
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent-600/0 to-accent-600/0 group-hover:from-accent-600/[0.04] group-hover:to-brand-600/[0.04] dark:group-hover:from-accent-600/10 dark:group-hover:to-brand-600/10 transition-all duration-300 pointer-events-none"></div>
        <div class="shrink-0 w-12 h-12 rounded-xl bg-accent-100/60 dark:bg-accent-900/30 border border-accent-200 dark:border-accent-800 flex items-center justify-center text-accent-600 dark:text-accent-400">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-mono font-medium text-ink-400 dark:text-ink-500 mb-0.5 uppercase tracking-wide">LinkedIn</p>
          <p class="text-ink-900 dark:text-gray-100 font-semibold">linkedin.com/in/betzmichael</p>
          <p class="text-ink-400 dark:text-ink-500 text-sm mt-0.5">Connect or send a message</p>
        </div>
        <svg class="w-5 h-5 text-ink-300 dark:text-ink-600 group-hover:text-accent-500 dark:group-hover:text-accent-400 group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

    </div>
  </section>
</BaseLayout>
