---
import BaseLayout from '../layouts/BaseLayout.astro';

const WEB3FORMS_KEY = '59f9d538-4fc1-47f1-893f-bff47c181e0b';
const TURNSTILE_SITE_KEY = '0x4AAAAAACniGOhFtWLSXcBt';
---

<BaseLayout title="Contact" description="Get in touch with Mike Betz.">
  <!-- Load Turnstile in <head> via named slot -->
  <script
    slot="head"
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <section class="relative max-w-2xl mx-auto px-6 py-16 overflow-hidden">
    <!-- Glow orbs -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-accent-600/10 dark:bg-accent-600/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-brand-600/10 dark:bg-brand-600/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8 bg-highlight-500"></div>
        <p class="font-mono text-xs text-highlight-500 tracking-widest uppercase">Reach Out</p>
      </div>
      <h1 class="text-4xl font-bold text-ink-900 dark:text-gray-100 mb-3">Get in Touch</h1>
      <p class="text-ink-500 dark:text-ink-400 text-lg">
        Have a question, want to collaborate, or just want to talk tech? Send me a message.
      </p>
    </div>

    <!-- Contact Form -->
    <form id="contact-form" class="relative space-y-5 mb-10">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New message from mikebetz.com" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-medium text-ink-700 dark:text-ink-300 mb-1.5">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Jane Smith"
            class="w-full border border-ink-200 dark:border-ink-700 bg-white dark:bg-ink-800/60 rounded-xl px-4 py-2.5 text-ink-900 dark:text-gray-100 placeholder-ink-300 dark:placeholder-ink-600 focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-600 focus:border-transparent transition"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-ink-700 dark:text-ink-300 mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="jane@example.com"
            class="w-full border border-ink-200 dark:border-ink-700 bg-white dark:bg-ink-800/60 rounded-xl px-4 py-2.5 text-ink-900 dark:text-gray-100 placeholder-ink-300 dark:placeholder-ink-600 focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-600 focus:border-transparent transition"
          />
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-ink-700 dark:text-ink-300 mb-1.5">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="Tell me what's on your mind..."
          class="w-full border border-ink-200 dark:border-ink-700 bg-white dark:bg-ink-800/60 rounded-xl px-4 py-2.5 text-ink-900 dark:text-gray-100 placeholder-ink-300 dark:placeholder-ink-600 focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-600 focus:border-transparent transition resize-none"
        ></textarea>
      </div>

      <!-- Turnstile widget -->
      <div
        class="cf-turnstile"
        data-sitekey={TURNSTILE_SITE_KEY}
        data-theme="auto"
      ></div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full sm:w-auto bg-brand-600 hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold px-8 py-3 rounded-xl transition-all duration-200 glow-brand flex items-center gap-2"
      >
        <span id="btn-text">Send Message</span>
        <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
      </button>

      <p id="form-success" class="hidden text-sm font-medium text-highlight-500 flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Message sent! I'll get back to you soon.
      </p>
      <p id="form-error" class="hidden text-sm font-medium text-red-500 flex items-center gap-2">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        Something went wrong. Please try again or reach out directly below.
      </p>
    </form>

    <!-- Divider -->
    <div class="flex items-center gap-4 mb-8">
      <div class="flex-1 h-px bg-ink-100 dark:bg-ink-800"></div>
      <span class="text-xs font-mono text-ink-400 dark:text-ink-500 uppercase tracking-widest">Or reach out directly</span>
      <div class="flex-1 h-px bg-ink-100 dark:bg-ink-800"></div>
    </div>

    <!-- Direct contact cards -->
    <div class="flex flex-col gap-4">

      <!-- Email -->
      <a
        href="mailto:michaelb187@gmail.com"
        class="group flex items-center gap-5 p-5 rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-800/40 hover:border-brand-400 dark:hover:border-brand-700 hover:shadow-lg dark:hover:shadow-brand-600/10 transition-all duration-300 overflow-hidden relative"
      >
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-600/0 to-brand-600/0 group-hover:from-brand-600/[0.04] group-hover:to-highlight-500/[0.04] dark:group-hover:from-brand-600/10 dark:group-hover:to-highlight-500/10 transition-all duration-300 pointer-events-none"></div>
        <div class="shrink-0 w-11 h-11 rounded-xl bg-brand-50 dark:bg-brand-900/40 border border-brand-100 dark:border-brand-700/50 flex items-center justify-center text-brand-600 dark:text-brand-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-mono font-medium text-ink-400 dark:text-ink-500 mb-0.5 uppercase tracking-wide">Email</p>
          <p class="text-ink-900 dark:text-gray-100 font-semibold text-sm">michaelb187@gmail.com</p>
          <p class="text-ink-400 dark:text-ink-500 text-xs mt-0.5">Opens in your default mail app</p>
        </div>
        <svg class="w-4 h-4 text-ink-300 dark:text-ink-600 group-hover:text-brand-500 dark:group-hover:text-brand-400 group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/betzmichael/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 p-5 rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-800/40 hover:border-accent-400 dark:hover:border-accent-700 hover:shadow-lg dark:hover:shadow-accent-600/10 transition-all duration-300 overflow-hidden relative"
      >
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent-600/0 to-accent-600/0 group-hover:from-accent-600/[0.04] group-hover:to-brand-600/[0.04] dark:group-hover:from-accent-600/10 dark:group-hover:to-brand-600/10 transition-all duration-300 pointer-events-none"></div>
        <div class="shrink-0 w-11 h-11 rounded-xl bg-accent-100 dark:bg-accent-800/50 border border-accent-200 dark:border-accent-700/60 flex items-center justify-center text-accent-600 dark:text-accent-300">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-mono font-medium text-ink-400 dark:text-ink-500 mb-0.5 uppercase tracking-wide">LinkedIn</p>
          <p class="text-ink-900 dark:text-gray-100 font-semibold text-sm">linkedin.com/in/betzmichael</p>
          <p class="text-ink-400 dark:text-ink-500 text-xs mt-0.5">Connect or send a message</p>
        </div>
        <svg class="w-4 h-4 text-ink-300 dark:text-ink-600 group-hover:text-accent-500 dark:group-hover:text-accent-400 group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>

    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text')!;
    const spinner = document.getElementById('btn-spinner')!;
    const successMsg = document.getElementById('form-success')!;
    const errorMsg = document.getElementById('form-error')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btnText.textContent = 'Sending...';
      spinner.classList.remove('hidden');
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const json = await res.json();

        if (json.success) {
          form.reset();
          successMsg.classList.remove('hidden');
          (window as any).turnstile?.reset();
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btnText.textContent = 'Send Message';
        spinner.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
