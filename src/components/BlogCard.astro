---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-ink-100 rounded-2xl p-6 hover:border-brand-200 hover:shadow-md transition-all duration-200">
  <a href={`/blog/${slug}`} class="block">
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map(tag => (
        <span class="bg-brand-50 text-brand-700 text-xs font-semibold px-2.5 py-0.5 rounded-full">
          {tag}
        </span>
      ))}
    </div>
    <h2 class="text-xl font-bold text-ink-900 mb-2 group-hover:text-brand-600 transition-colors leading-snug">
      {title}
    </h2>
    <p class="text-ink-500 text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex items-center justify-between">
      <time class="text-xs text-ink-400">{formattedDate}</time>
      <span class="text-brand-600 text-sm font-medium group-hover:translate-x-1 transition-transform inline-block">
        Read more &rarr;
      </span>
    </div>
  </a>
</article>
