---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group relative border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-800/40 rounded-2xl p-6 hover:border-brand-400 dark:hover:border-brand-700 hover:shadow-lg dark:hover:shadow-brand-600/10 transition-all duration-300 overflow-hidden">
  <!-- Hover gradient overlay -->
  <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-600/0 to-accent-600/0 group-hover:from-brand-600/[0.04] group-hover:to-accent-600/[0.04] dark:group-hover:from-brand-600/10 dark:group-hover:to-accent-600/10 transition-all duration-300 pointer-events-none"></div>

  <a href={`/blog/${slug}`} class="relative block">
    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map(tag => (
        <span class="bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-300 border border-brand-100 dark:border-brand-800 text-xs font-mono font-medium px-2.5 py-0.5 rounded-full">
          {tag}
        </span>
      ))}
    </div>

    <h2 class="text-xl font-bold text-ink-900 dark:text-gray-100 mb-2 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors leading-snug">
      {title}
    </h2>
    <p class="text-ink-500 dark:text-ink-400 text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>

    <div class="flex items-center justify-between">
      <time class="text-xs text-ink-400 dark:text-ink-500 font-mono">{formattedDate}</time>
      <span class="text-brand-600 dark:text-brand-400 text-sm font-medium group-hover:translate-x-1 transition-transform inline-block">
        Read more &rarr;
      </span>
    </div>
  </a>
</article>
