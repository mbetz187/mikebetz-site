---
const navLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-ink-200 dark:border-ink-800 bg-white/80 dark:bg-ink-900/90 backdrop-blur-md transition-colors duration-300">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-bold text-xl tracking-tight flex items-center gap-1">
      <span class="bg-gradient-to-r from-brand-600 to-highlight-500 bg-clip-text text-transparent">Michael</span>
      <span class="text-ink-900 dark:text-gray-100"> Betz</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden sm:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors relative group ${
              currentPath.startsWith(link.href)
                ? 'text-brand-600 dark:text-brand-400'
                : 'text-ink-600 dark:text-ink-400 hover:text-brand-600 dark:hover:text-brand-400'
            }`}
          >
            {link.label}
            <span class={`absolute -bottom-1 left-0 h-0.5 bg-brand-600 dark:bg-brand-400 transition-all duration-200 ${
              currentPath.startsWith(link.href) ? 'w-full' : 'w-0 group-hover:w-full'
            }`}></span>
          </a>
        </li>
      ))}

      <!-- Social Links -->
      <li>
        <a
          href="https://www.linkedin.com/in/betzmichael/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-400 dark:text-ink-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
          aria-label="LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </li>
      <li>
        <a
          href="https://github.com/mbetz187"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-400 dark:text-ink-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </li>

      <!-- Dark / Light Mode Toggle -->
      <li>
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="theme-pill flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-ink-200 dark:border-ink-700 bg-ink-50 dark:bg-ink-800 text-xs font-medium text-ink-600 dark:text-ink-300 hover:border-brand-400 dark:hover:border-brand-600 transition-all duration-200 select-none"
        >
          <!-- Sun icon -->
          <svg class="hidden dark:block w-3.5 h-3.5 text-highlight-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <span class="hidden dark:inline">Light</span>
          <!-- Moon icon -->
          <svg class="block dark:hidden w-3.5 h-3.5 text-accent-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <span class="inline dark:hidden">Dark</span>
        </button>
      </li>
    </ul>

    <!-- Mobile Controls -->
    <div class="flex sm:hidden items-center gap-2">
      <button
        id="theme-toggle-mobile"
        aria-label="Toggle dark mode"
        class="theme-pill flex items-center gap-1 px-2.5 py-1.5 rounded-full border border-ink-200 dark:border-ink-700 bg-ink-50 dark:bg-ink-800 text-xs font-medium text-ink-600 dark:text-ink-300 transition-all duration-200 select-none"
      >
        <svg class="hidden dark:block w-3.5 h-3.5 text-highlight-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <span class="hidden dark:inline">Light</span>
        <svg class="block dark:hidden w-3.5 h-3.5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <span class="inline dark:hidden">Dark</span>
      </button>
      <button
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
        class="p-1.5 rounded-lg text-ink-400 dark:text-ink-500 hover:bg-ink-100 dark:hover:bg-ink-800 transition-colors"
      >
        <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-ink-100 dark:border-ink-800 bg-white dark:bg-ink-900 transition-colors">
    <div class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium px-3 py-2 rounded-lg transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-900/20'
              : 'text-ink-600 dark:text-ink-400 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-ink-50 dark:hover:bg-ink-800'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-4 px-3 pt-3 mt-1 border-t border-ink-100 dark:border-ink-800">
        <a href="https://www.linkedin.com/in/betzmichael/" target="_blank" rel="noopener noreferrer"
          class="text-ink-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
        <a href="https://github.com/mbetz187" target="_blank" rel="noopener noreferrer"
          class="text-ink-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  mobileToggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
