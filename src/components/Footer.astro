  <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ink-400 dark:text-ink-500">
    <p class="font-mono text-xs">&copy; {year} <span class="text-ink-600 dark:text-ink-300 font-medium">Mike Betz</span>. All rights reserved.</p>
    <div class="flex gap-6">
      <a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Blog</a>
      <a href="/contact" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Contact</a>
      <a href="https://github.com/mbetz187" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">GitHub</a>
    </div>
  </div>
</footer>
